# =============================================================
# VEKTOR A.I — Environment variables
# Copy this file to .env and fill the values for your environment.
# Never commit .env to git.
# =============================================================

# ---------- App ----------
NODE_ENV=production
APP_URL=https://vektor.yourdomain.com
APP_NAME="VEKTOR A.I"

# ---------- Frontend (TanStack Start) ----------
FRONTEND_PORT=3000

# ---------- Backend (Fastify — phase 2) ----------
BACKEND_PORT=4000
BACKEND_URL=http://backend:4000
JWT_SECRET=change-me-with-a-long-random-string
SESSION_SECRET=change-me-with-a-long-random-string

# ---------- PostgreSQL ----------
POSTGRES_USER=vektor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vektor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vektor:change-me@postgres:5432/vektor

# ---------- Redis / BullMQ ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------- AI Providers ----------
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ---------- WhatsApp (Evolution API) ----------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ---------- SMTP ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="VEKTOR A.I <no-reply@yourdomain.com>"
