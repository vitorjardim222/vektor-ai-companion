// VEKTOR A.I — Prisma schema
// Multi-tenant SaaS foundation: organizations, memberships, workspaces,
// plans, subscriptions, usage and audit logs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  SUPPORT
  BILLING
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum IptvCustomerPlanStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
  CUSTOM
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  name          String?
  avatarUrl     String?
  emailVerified Boolean      @default(false)
  twoFactorOn   Boolean      @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships   Membership[]
  auditLogs     AuditLog[]
  usageLogs     UsageLog[]
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  logoUrl       String?
  blocked       Boolean        @default(false)
  whiteLabel    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  workspaces    Workspace[]
  subscriptions Subscription[]
  usageLogs     UsageLog[]
  auditLogs     AuditLog[]
  iptvPlans         IptvPlan[]
  iptvCustomerPlans IptvCustomerPlan[]
  iptvRenewalRules  IptvRenewalRule[]
  whatsappSessions  WhatsAppSession[]
  whatsappEvents    WhatsAppEvent[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Workspace {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
}

model Plan {
  id               String         @id @default(cuid())
  name             String         @unique
  tier             PlanTier
  priceCents       Int            @default(0)
  maxWhatsapp      Int            @default(1)
  maxAgents        Int            @default(1)
  maxMessages      Int            @default(1000)
  maxUsers         Int            @default(3)
  whiteLabel       Boolean        @default(false)
  apiAccess        Boolean        @default(false)
  createdAt        DateTime       @default(now())

  subscriptions    Subscription[]
}

model Subscription {
  id                String             @id @default(cuid())
  organizationId    String
  planId            String
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodEnd  DateTime?
  trialEndsAt       DateTime?
  canceledAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
}

model UsageLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  kind           String       // e.g. "ai.tokens", "whatsapp.message"
  amount         Int          @default(1)
  metadata       Json?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, kind, createdAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  target         String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime     @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model IptvPlan {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  description       String?
  durationDays      Int      @default(30)
  price             Decimal  @default(0)
  currency          String   @default("BRL")
  connectionsLimit  Int      @default(1)
  trialEnabled      Boolean  @default(false)
  trialDurationHours Int     @default(0)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerPlans  IptvCustomerPlan[]
  renewalRules   IptvRenewalRule[]

  @@index([organizationId, active, sortOrder])
}

model IptvCustomerPlan {
  id             String                 @id @default(cuid())
  organizationId String
  contactId      String
  planId         String
  startDate      DateTime               @default(now())
  expiresAt      DateTime
  status         IptvCustomerPlanStatus @default(ACTIVE)
  autoRenew      Boolean                @default(true)
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         IptvPlan     @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([organizationId, status, expiresAt])
  @@index([contactId])
}

model IptvRenewalRule {
  id                  String   @id @default(cuid())
  organizationId      String
  planId              String?
  reminderDaysBefore  Int[]    @default([7, 3, 1, 0])
  overdueDaysAfter    Int[]    @default([1, 3, 7])
  assignedAiPoolId    String?
  messageTemplate     String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         IptvPlan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

enum ContactStatus {
  ATIVO
  INATIVO
  BLOQUEADO
  LEAD
}

model Contact {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  phone             String
  email             String?
  avatar            String?
  source            String?
  status            String        @default("ativo")
  tags              String[]      @default([])
  notes             String?
  leadStage         String?
  assignedUserId    String?
  assignedAiPoolId  String?
  iptvPlanId        String?
  iptvExpiresAt     DateTime?
  lastInteractionAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, phone])
}

enum WhatsAppStatus {
  DISCONNECTED
  CONNECTING
  QR
  CONNECTED
  ERROR
}

model WhatsAppSession {
  id                  String         @id @default(cuid())
  organizationId      String
  name                String
  phoneNumber         String?
  status              WhatsAppStatus @default(DISCONNECTED)
  evolutionSessionId  String?        @unique
  qrCode              String?
  lastConnectionAt    DateTime?
  lastMessageAt       DateTime?
  assignedPoolId      String?
  assignedHumanId     String?
  autoReconnect       Boolean        @default(true)
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events              WhatsAppEvent[]

  @@index([organizationId, status])
  @@index([organizationId, active])
}

model WhatsAppEvent {
  id              String           @id @default(cuid())
  organizationId  String
  sessionId       String?
  type            String
  payload         Json
  createdAt       DateTime         @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session         WhatsAppSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([sessionId, createdAt])
}
