# =============================================================
# VEKTOR A.I — PRODUCTION env (VPS vps8817)
# Copy to .env on the VPS:
#   cp .env.production.example .env
# Never commit the real .env.
# =============================================================

# ---------- App ----------
NODE_ENV=production
APP_URL=http://vektor.vps8817.panel.icontainer.net
APP_NAME="VEKTOR A.I"

# ---------- Ports (host-bound to 127.0.0.1, proxied by OpenResty) ----------
FRONTEND_PORT=3011
BACKEND_PORT=3012

# ---------- Frontend ----------
# Same-origin: OpenResty proxies /api -> backend:3012
VITE_API_BASE_URL=/api

# ---------- Backend ----------
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_32_CHARS
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# ---------- PostgreSQL (REUSE existing container ic-postgresql-aIFq) ----------
# Create the DB/user inside the existing container before deploy:
#   docker exec -it ic-postgresql-aIFq psql -U user_mrWMXr -c \
#     "CREATE USER vektor WITH PASSWORD 'CHANGE_ME'; CREATE DATABASE vektor OWNER vektor;"
POSTGRES_USER=vektor
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=vektor
POSTGRES_HOST=ic-postgresql-aIFq
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vektor:CHANGE_ME@ic-postgresql-aIFq:5432/vektor

# ---------- Redis (REUSE existing container ic-redis-zf84) ----------
REDIS_HOST=ic-redis-zf84
REDIS_PORT=6379
REDIS_URL=redis://ic-redis-zf84:6379

# ---------- Evolution API (REUSE existing container ic-evolutionapi-8nZx) ----------
# Internal URL used by backend; public URL only for reference / webhooks.
EVOLUTION_API_URL=http://ic-evolutionapi-8nZx:8080
EVOLUTION_API_PUBLIC_URL=https://evolutionapi.vps8817.panel.icontainer.net
EVOLUTION_API_KEY=CHANGE_ME

# ---------- AI providers (optional) ----------
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ---------- SMTP (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="VEKTOR A.I <no-reply@vps8817.panel.icontainer.net>"
