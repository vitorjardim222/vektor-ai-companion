# =============================================================
# VEKTOR A.I — PRODUCTION env (VPS)
# Copy to .env on the VPS:
#   cp .env.production.example .env
# Never commit the real .env.
# =============================================================

# ---------- App ----------
NODE_ENV=production
APP_URL=https://vektor.yourdomain.com
APP_NAME="VEKTOR A.I"

# ---------- Ports (host-bound to 127.0.0.1, proxied by OpenResty) ----------
FRONTEND_PORT=3011
BACKEND_PORT=3012

# ---------- Frontend ----------
# Same-origin: OpenResty proxies /api -> backend:3012
VITE_API_BASE_URL=/api

# ---------- Backend ----------
JWT_SECRET=CHANGE-ME-LONG-RANDOM-STRING-MIN-32-CHARS
SESSION_SECRET=CHANGE-ME-LONG-RANDOM-STRING

# ---------- PostgreSQL (REUSE existing container) ----------
# Reachable over the "shared" docker network.
POSTGRES_USER=vektor
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=vektor
POSTGRES_HOST=ic-postgresql-aIFq
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vektor:CHANGE-ME@ic-postgresql-aIFq:5432/vektor

# ---------- Redis (REUSE existing container) ----------
REDIS_HOST=ic-redis-zf84
REDIS_PORT=6379
REDIS_URL=redis://ic-redis-zf84:6379

# ---------- Evolution API (REUSE existing container) ----------
EVOLUTION_API_URL=http://ic-evolutionapi-8nZx:8080
EVOLUTION_API_KEY=CHANGE-ME

# ---------- AI providers (optional) ----------
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ---------- SMTP (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="VEKTOR A.I <no-reply@yourdomain.com>"
